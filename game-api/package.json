{
  "name": "kyomuusa-ranking-api",
  "version": "0.1.0",
  "private": true,
  "description": "CasLive きょむうさ猛プッシュ — ranking API (Cloudflare Workers + KV)",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "kv:create": "wrangler kv namespace create RANKING",
    "kv:create-preview": "wrangler kv namespace create RANKING --preview",
    "kv:top100": "wrangler kv key get --binding=RANKING top100"
  },
  "devDependencies": {
    "wrangler": "^4.84.1"
  }
}
